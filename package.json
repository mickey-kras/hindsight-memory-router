{
  "name": "hindsight-memory-router",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security:audit": "npm audit --audit-level=moderate",
    "aislop:ci": "npx --yes aislop@latest ci --changes --base origin/main",
    "aislop:fix:safe": "npx --yes aislop@latest fix --safe",
    "check": "npm run format:check && npm run lint && npm test && npm run typecheck && npm run security:audit && npm run aislop:ci",
    "fix": "npm run format && npm run lint:fix && npm run aislop:fix:safe",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.6.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.9"
  }
}
